# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Job Portal"
APP_VERSION="1.0.0"
DEBUG=false

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/neondb?ssl=require

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI (OpenRouter) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=JobPortal <no-reply@yourdomain.com>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS_STR=https://your-frontend.vercel.app,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
